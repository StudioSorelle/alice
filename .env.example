# Database (Turso)
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# Image generation (Replicate)
REPLICATE_API_TOKEN=r8_...

# Image storage (Cloudflare R2)
CLOUDFLARE_R2_ACCOUNT_ID=your-account-id
CLOUDFLARE_R2_ACCESS_KEY_ID=your-r2-key-id
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your-r2-secret
CLOUDFLARE_R2_BUCKET=alice-moments
CLOUDFLARE_R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# Email (Resend) — for daily moderation digest
RESEND_API_KEY=re_...
NOTIFY_EMAIL=info@studiosorelle.be

# App
ADMIN_PASSWORD=choose-a-strong-password
APP_URL=https://creationlab.studiosorelle.be
FEEDBACK_URL=

# Local dev only
PORT=3000
